# Application
MAF_LAB_HOST=127.0.0.1
MAF_LAB_PORT=8000
MAF_LAB_DATA_DIR=./data
MAF_LAB_LOG_LEVEL=INFO

# OpenAI-compatible provider for the real Microsoft Agent Framework mode.
# Standard OpenAI: leave OPENAI_BASE_URL empty.
# Ollama example: OPENAI_BASE_URL=http://localhost:11434/v1/
# Requesty or another compatible gateway: use its documented /v1 endpoint.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano
OPENAI_BASE_URL=
