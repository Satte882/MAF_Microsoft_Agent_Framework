# Application
MAF_LAB_HOST=127.0.0.1
MAF_LAB_PORT=8000
MAF_LAB_DATA_DIR=./data
MAF_LAB_LOG_LEVEL=INFO

# OpenAI-kompatibler Provider für den echten Microsoft Agent Framework Modus.
# OpenRouter (empfohlen): OPENAI_BASE_URL=https://openrouter.ai/api/v1
# Ollama (lokal): OPENAI_BASE_URL=http://localhost:11434/v1/
# Standard OpenAI: OPENAI_BASE_URL leer lassen.
OPENAI_API_KEY=
OPENAI_MODEL=deepseek/deepseek-v4-flash
OPENAI_BASE_URL=https://openrouter.ai/api/v1
